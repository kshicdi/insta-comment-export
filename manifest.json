{
  "manifest_version": 3,
  "name": "인스타 댓글 스카우트",
  "version": "0.1.0",
  "description": "인스타그램 게시물 댓글을 엑셀로 추출하는 도구. 한끗랩 원스카우트.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "static/images/icon16.png",
    "32": "static/images/icon32.png",
    "48": "static/images/icon48.png",
    "128": "static/images/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "인스타 댓글 스카우트",
    "default_icon": {
      "16": "static/images/icon16.png",
      "32": "static/images/icon32.png",
      "48": "static/images/icon48.png",
      "128": "static/images/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "lib/xlsx.full.min.js",
        "content/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
